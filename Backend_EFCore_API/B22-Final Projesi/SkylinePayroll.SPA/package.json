    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.4",
    "@tailwindcss/postcss": "^4.2.1",
    "bootstrap": "^5.3.8",
    "express": "^5.1.0",
    "jwt-decode": "^4.0.0",
    "ngx-toastr": "^20.0.5",
