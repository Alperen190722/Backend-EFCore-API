<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Northwind</title>

    <link href="/node_modules/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f8f9fa;
        }

        .main-container {
            margin-top: 80px;
            min-height: 85vh;
        }

        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Admin" asp-action="Index">NORTHWIND ADMIN PANEL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" asp-controller="Product" asp-action="Index">Products Store</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                           User
                        </a>
                    @await Component.InvokeAsync("UserSummary")
                    </li>
                </ul>
            </div>
        </div>
    </nav>

            <div class="col-md-9">
        <div class="mainbox col-md-6 col-md-offset-3 col-sm-8 col-sm-offset-2">
                    @if (TempData["message"] != null)
                    {
                        <div class="alert alert-info" role="alert">@TempData["message"]</div>
                    }
                    @RenderBody()
                </div>
            </div>

    <footer class="footer mt-5 py-3 bg-white border-top text-center text-muted">
        <div class="container">
            &copy; 2026 - Northwind Management System
        </div>
    </footer>

    <script src="/node_modules/jquery/dist/jquery.min.js"></script>
    <script src="/node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/node_modules/jquery-validation/dist/jquery.validate.js"></script>
    <script src="/node_modules/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>