@model D40_Abc.Northwind.MvcWebUI.Models.ProductListViewModel
<h1>Sayfa Sayısı: @Model.PageCount</h1>
@{
    Layout = "~/Views/_Layout.cshtml";
}
<div>
       <table class="table table-responsive">
           <tr>
               <td>Product Name</td>
               <td>Unit Price</td>
               <td>Unit In Stock</td>
           </tr>
            @foreach (var product in Model.Products)
            {
               <tr>
                   <td>@product.ProductName</td>
                    <td>@product.UnitPrice</td>
                    <td>@product.UnitsInStock</td>
                    <td><a class="btn btn-xs btn-success" asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@product.ProductId">add to cart</a></td>
               </tr> 
            }
        </table>
</div>
<nav aria-label="Page navigation">
    <ul class="pagination">
        @for (int i = 1; i <= Model.PageCount; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link" href="/product/index?page=@i&category=@Model.CurrentCategory">@i</a>
            </li>
        }
    </ul>
</nav>
